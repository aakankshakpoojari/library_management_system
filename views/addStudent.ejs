<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="main-page">

        <h1>Add Student</h1>

        <form action="/students/add" method="POST">

            <input
                type="text"
                name="usn"
                placeholder="USN"
                required
            >


            <input
                type="text"
                name="name"
                placeholder="Student Name"
                required
            >

            <input
                type="text"
                name="branch"
                placeholder="Branch"
                required
            >

            <button type="submit">
                Add Student
            </button>

        </form>

    </div>

</body>
</html>
